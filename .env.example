# wildlens configuration (copy to .env and adjust). All optional.

# --- Server ---
WILDLENS_HOST=0.0.0.0
WILDLENS_PORT=8000
# Idle auto-shutdown (seconds). 0 = always on. The socket-activated systemd unit
# sets this to 600 so the server exits when unused and restarts on next request.
WILDLENS_IDLE_TIMEOUT=0

# --- Identification (runs at ingest time only) ---
# none  : no image-based ID, but photos still get place names + Wikipedia facts
# mock  : demo fauna/flora subjects
# claude: real flora/fauna/landmark ID via the Claude CLI (needs `claude` installed)
WILDLENS_ID_PROVIDER=none
WILDLENS_GEOCODE_ENABLED=true       # GPS -> place name (Nominatim, no key)
WILDLENS_FACTS_ENABLED=true         # place/subject -> fun fact (Wikipedia, no key)

# --- Near-duplicate grouping (perceptual hash, ingest-time) ---
WILDLENS_DEDUP_ENABLED=true
WILDLENS_DEDUP_THRESHOLD=14         # max Hamming distance (0-64); higher = looser
WILDLENS_DEDUP_TIME_WINDOW=300      # only group photos taken within N seconds

# --- Location inference (for media missing GPS) ---
WILDLENS_INFER_LOCATION_ENABLED=true
WILDLENS_INFER_LOCATION_WINDOW=1800 # use nearest located photo within N seconds
# WILDLENS_CLAUDE_BIN=claude
# WILDLENS_CLAUDE_TIMEOUT=120

# --- Thumbnails ---
WILDLENS_THUMB_SIZE=480

# --- OneDrive import (optional) ---
# Create a free Azure app registration (Personal Microsoft accounts only),
# enable "Allow public client flows", add Graph delegated Files.Read + offline_access,
# then put the Application (client) ID here. Leave empty to hide the feature.
WILDLENS_ONEDRIVE_CLIENT_ID=
# Authority tenant: consumers (personal MS accounts), common, or a tenant id.
WILDLENS_ONEDRIVE_TENANT=consumers

# --- Backups (deploy/wildlens-backup.sh) ---
# WILDLENS_BACKUP_DIR=$HOME/wildlens-backups
# WILDLENS_BACKUP_KEEP=7
# RESTIC_REPOSITORY=
# HC_PING_URL=

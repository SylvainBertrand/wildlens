# wildlens configuration (copy to .env and adjust). All optional.
# Server binding — 0.0.0.0 exposes it on the LAN (default).
WILDLENS_HOST=0.0.0.0
WILDLENS_PORT=8000
# Identification provider: mock (default). Later: clip, wikipedia, claude...
WILDLENS_ID_PROVIDER=mock
# Thumbnail max edge in pixels.
WILDLENS_THUMB_SIZE=480
